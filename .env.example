# Azure AI Foundry Agent
FOUNDRY_ENDPOINT=
FOUNDRY_AGENT_NAME=
FOUNDRY_AGENT_VERSION=4

# Azure AD — Service Principal
# Crea un App Registration in Azure AD, assegna il ruolo "Azure AI Developer"
# sul Foundry project, e inserisci le credenziali qui sotto.
AZURE_TENANT_ID=<tenant-id>
AZURE_CLIENT_ID=<client-id>
AZURE_CLIENT_SECRET=<client-secret>

# Playwright
PLAYWRIGHT_TIMEOUT_MS=30000
PLAYWRIGHT_SCREENSHOT=false
PLAYWRIGHT_OCR=true

# Worker
N_WORKERS=3
JOB_TTL_SECONDS=3600

# Trellix IVX — Token Auth (opzionale)
TRELLIX_API_TOKEN=

# IOC Feed — Token Auth (opzionale, separato da Trellix)
IOC_API_TOKEN=
